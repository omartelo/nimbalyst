{
  "id": "com.nimbalyst.example-theme",
  "name": "Example Theme",
  "version": "1.0.0",
  "description": "Manifest-only example theme extension. Demonstrates contributions.themes wiring and the no-JS theme-extension shape.",
  "apiVersion": "1.0",
  "requiredReleaseChannel": "alpha",
  "defaultEnabled": true,
  "contributions": {
    "themes": [
      {
        "id": "midnight-orchid",
        "name": "Midnight Orchid",
        "isDark": true,
        "colors": {
          "bg": "#1a0f24",
          "bg-secondary": "#241334",
          "bg-tertiary": "#311a45",
          "bg-hover": "rgba(255, 255, 255, 0.06)",
          "bg-selected": "rgba(196, 132, 252, 0.16)",
          "bg-active": "rgba(196, 132, 252, 0.22)",
          "text": "#f4ecff",
          "text-muted": "#c4b8d8",
          "text-faint": "#8b7d9e",
          "text-disabled": "#5a4f6a",
          "border": "#3a2854",
          "border-focus": "#c084fc",
          "primary": "#c084fc",
          "primary-hover": "#a855f7",
          "link": "#d8b4fe",
          "link-hover": "#e9d5ff",
          "success": "#86efac",
          "warning": "#fde68a",
          "error": "#fca5a5",
          "info": "#a5b4fc",
          "purple": "#c084fc"
        }
      }
    ]
  }
}
